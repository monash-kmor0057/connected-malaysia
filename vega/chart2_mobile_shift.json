{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 260,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of short message services (SMS)sent (billion)'"
    }

  ],

  "mark": {
    "type": "area",
    "line": true,
    "point": true,
    "color": "#dc2626",
    "opacity": 0.6
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "title": "SMS Sent"
    }
  }
}
