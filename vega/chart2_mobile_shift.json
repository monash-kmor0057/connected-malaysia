{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 240,

  "data": {
    "url": "../data/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' && (datum['Sub-Items'] == 'Post paid' || datum['Sub-Items'] == 'Prepaid')"
    }
  ],

  "mark": {
    "type": "area",
    "opacity": 0.8
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative",
      "stack": true,
      "title": "Subscriptions (Thousand)"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal",
      "scale": {
        "range": ["#2563eb", "#60a5fa"]
      }
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal"
      },
      {
        "field": "Sub-Items",
        "type": "nominal"
      },
      {
        "field": "Value in Thousand",
        "type": "quantitative"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}
