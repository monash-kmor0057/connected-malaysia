{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 260,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of short message services (SMS)sent (billion)'"
    },

    {
      "filter": "datum.Value_in_Thousand > 0"
    }

  ],

  "mark": {
    "type": "area",
    "line": {
      "strokeWidth": 4
    },
    "point": true,
    "color": "#ef4444",
    "opacity": 0.55
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "ordinal"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "title": "SMS Sent (Billions)"
    }
  }
}
