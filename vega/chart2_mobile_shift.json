{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 320,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of short message services (SMS)sent (billion)'"
    },

    {
      "filter": "datum.Value_in_Thousand > 0"
    }

  ],

  "mark": {
    "type": "line",
    "interpolate": "cardinal",
    "point": true,
    "strokeWidth": 4,
    "color": "#dc2626"
  },

  "encoding": {

    "theta": {
      "field": "Year",
      "type": "ordinal"
    },

    "radius": {
      "field": "Value_in_Thousand",
      "type": "quantitative"
    }
  }
}
