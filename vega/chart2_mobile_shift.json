{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 240,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == 'Post paid' || datum['Sub-Items'] == 'Prepaid'"
    },

    {
      "calculate": "datum['Sub-Items'] == 'Post paid' ? 'Postpaid' : 'Prepaid'",
      "as": "Category"
    }

  ],

  "mark": {
    "type": "area",
    "opacity": 0.75
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "title": "Subscriptions",
      "stack": true
    },

    "color": {
      "field": "Category",
      "type": "nominal",

      "scale": {
        "range": ["#2563eb", "#93c5fd"]
      },

      "legend": {
        "title": null,
        "orient": "top"
      }
    },

    "tooltip": [

      {
        "field": "Year"
      },

      {
        "field": "Category"
      },

      {
        "field": "Value_in_Thousand"
      }

    ]
  }
}
