{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 220,

  "data": {
    "url": "../data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(datum['Value in Thousand'])",
      "as": "value"
    }
  ],

  "mark": {
    "type": "area",
    "opacity": 0.7
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "stack": true,
      "title": "Subscriptions (Thousand)"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal"
    }
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}
