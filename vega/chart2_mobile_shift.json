{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 240,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    },

    {
      "filter": "datum.SubItems == 'Post paid' || datum.SubItems == 'Prepaid'"
    }
  ],

  "mark": {
    "type": "area",
    "opacity": 0.75
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value",
      "type": "quantitative",
      "title": "Subscriptions (Thousand)",
      "stack": true
    },

    "color": {
      "field": "SubItems",
      "type": "nominal",
      "scale": {
        "range": ["#2563eb", "#93c5fd"]
      },
      "legend": {
        "title": null
      }
    },

    "tooltip": [
      {
        "field": "Year"
      },
      {
        "field": "SubItems"
      },
      {
        "field": "Value"
      }
    ]
  }
}
