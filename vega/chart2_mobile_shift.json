function createChart2() {

    const spec = {
        "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

        "width": 320,
        "height": 240,

        "data": {
            "url": "data/telecommunications_statistics_malaysia.csv"
        },

        "mark": {
            "type": "area",
            "opacity": 0.8
        },

        "encoding": {
            "x": {
                "field": "year",
                "type": "ordinal",
                "title": "Year"
            },

            "y": {
                "field": "value",
                "type": "quantitative",
                "stack": "normalize",
                "title": "Share"
            },

            "color": {
                "field": "variable",
                "type": "nominal",
                "scale": {
                    "range": ["#2563eb", "#60a5fa"]
                }
            }
        }
    };

    vegaEmbed('#chart2', spec, {actions:false});
}
