{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 220,

  "data": {
    "url": "../data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    },
    {
      "filter": "datum['Sub-Items'] == 'Post paid' || datum['Sub-Items'] == 'Prepaid'"
    },
    {
      "calculate": "toNumber(datum['Value in Thousand'])",
      "as": "value"
    }
  ],

  "mark": {
    "type": "area",
    "opacity": 0.8
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "stack": true,
      "title": "Subscriptions (Thousand)"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal",
      "scale": {
        "range": ["#2563eb", "#60a5fa"]
      },
      "legend": {
        "title": null
      }
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal"
      },
      {
        "field": "Sub-Items",
        "type": "nominal"
      },
      {
        "field": "value",
        "type": "quantitative"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}
