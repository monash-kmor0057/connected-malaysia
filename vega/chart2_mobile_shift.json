{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 260,
  "height": 220,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    },
    {
      "filter": "datum.SubItems == 'Post paid' || datum.SubItems == 'Prepaid'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value",
      "type": "quantitative"
    },

    "color": {
      "field": "SubItems",
      "type": "nominal"
    }
  }
}
