{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Speed improvement by state 2020 Q1 to 2026 Q1",
  "width": "container",
  "height": 320,
  "data": {"url": "../../data/cleaned/state_speed_change.json"},
  "layer": [
    {
      "mark": {"type": "rule", "strokeWidth": 2},
      "encoding": {
        "y": {
          "field": "state", "type": "nominal", "sort": "-x",
          "title": null, "axis": {"labelFontSize": 12}
        },
        "x": {"field": "speed_2020", "type": "quantitative", "title": "Speed (Mbps)", "scale": {"domain": [0, 90]}},
        "x2": {"field": "speed_2026"},
        "color": {
          "field": "change", "type": "quantitative",
          "scale": {"scheme": "tealblues", "domain": [14, 57]},
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 70, "opacity": 0.5},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "speed_2020", "type": "quantitative"},
        "color": {"value": "#B4B2A9"},
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "speed_2020", "title": "2020 Q1 speed (Mbps)", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 100},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "speed_2026", "type": "quantitative"},
        "color": {
          "field": "change", "type": "quantitative",
          "scale": {"scheme": "tealblues", "domain": [14, 57]},
          "legend": {"title": "+Mbps gain", "orient": "bottom-right", "gradientLength": 100}
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "speed_2026", "title": "2026 Q1 speed (Mbps)", "format": ".1f"},
          {"field": "change", "title": "Speed gain (Mbps)", "format": "+.1f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 7, "fontSize": 11, "fontWeight": "bold"},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "speed_2026", "type": "quantitative"},
        "text": {"field": "change", "format": "+.1f"},
        "color": {
          "field": "change", "type": "quantitative",
          "scale": {"scheme": "tealblues", "domain": [14, 57]}
        }
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}, "font": "inherit"}
}
