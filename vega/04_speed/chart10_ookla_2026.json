{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Median download speed by tile - 2026 Q1",
  "width": "container",
  "height": 280,
  "projection": {"type": "mercator", "scale": 1800, "center": [109.5, 4.0]},
  "layer": [
    {
      "data": {
        "url": "../../data/geo/ookla-2026q1.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {"type": "geoshape", "stroke": "none"},
      "encoding": {
        "color": {
          "field": "properties.avg_d_mbps", "type": "quantitative",
          "scale": {"scheme": "yelloworangered", "domain": [0, 125]},
          "legend": {"title": "Mbps", "orient": "bottom-right", "gradientLength": 100}
        },
        "tooltip": [
          {"field": "properties.state", "title": "State"},
          {"field": "properties.avg_d_mbps", "title": "Avg speed (Mbps)", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}}
}
