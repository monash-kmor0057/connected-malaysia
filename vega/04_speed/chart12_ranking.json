{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Malaysia global speed ranking 2017-2024",
  "width": "container",
  "height": 260,
  "data": {"url": "../../data/cleaned/speed_history.json"},
  "transform": [
    {"filter": "datum.country == 'Malaysia'"}
  ],
  "layer": [
    {
      "mark": {"type": "area", "interpolate": "monotone", "color": "#185FA5", "opacity": 0.1},
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "title": "Year"},
        "y": {
          "field": "speed", "type": "quantitative",
          "title": "Download speed (Mbps)",
          "scale": {"domain": [0, 95]},
          "axis": {"labelFontSize": 11, "grid": true, "gridOpacity": 0.25}
        }
      }
    },
    {
      "mark": {"type": "line", "interpolate": "monotone", "strokeWidth": 3, "color": "#185FA5"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "speed", "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 80, "color": "#185FA5"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "speed", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "speed", "title": "Speed (Mbps)", "format": ".1f"},
          {"field": "rank", "title": "Global rank"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -14, "fontSize": 10, "fontWeight": "bold", "color": "#185FA5"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "speed", "type": "quantitative"},
        "text": {"field": "speed", "format": ".0f"}
      }
    },
    {
      "mark": {"type": "text", "dy": 14, "fontSize": 10, "color": "#888780"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "speed", "type": "quantitative"},
        "text": {"field": "rank", "format": "#"}
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}, "font": "inherit"}
}
