{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 440,
  "padding": { "top": 2, "bottom": 4, "left": 0, "right": 0 },
  "data": { "url": "data/csv/bqoes_2024.csv" },
  "transform": [
    {
      "filter": "datum.category == 'SQG_importance' || datum.category == 'SQG_satisfaction'"
    },
    {
      "calculate": "datum.category == 'SQG_importance' ? 'Importance' : 'Satisfaction'",
      "as": "metric"
    },
    {
      "calculate": "datum.broadband_type == 'FBB' ? 'Fixed (FBB)' : 'Mobile (MBB)'",
      "as": "broadband_label"
    }
  ],
  "facet": {
    "field": "metric",
    "type": "nominal",
    "columns": 2,
    "sort": ["Importance", "Satisfaction"],
    "title": null,
    "header": { "labelFontSize": 13, "labelFontWeight": 700, "labelColor": "#0f172a", "labelPadding": 6 }
  },
  "spec": {
    "width": 190,
    "height": 448,
    "padding": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
    "mark": { "type": "rect", "cornerRadius": 5 },
    "encoding": {
      "y": {
        "field": "scope",
        "type": "nominal",
        "title": null,
        "sort": [
          "Video streaming",
          "Web browsing",
          "Online gaming",
          "Online voice calls",
          "Online video calls"
        ],
        "axis": { "labelFontSize": 11, "labelLimit": 130, "labelPadding": 4 }
      },
      "x": {
        "field": "broadband_label",
        "type": "nominal",
        "title": null,
        "axis": {
          "labelFontSize": 11,
          "labelAngle": 0,
          "labelAlign": "center",
          "labelPadding": 8
        }
      },
      "color": {
        "field": "value",
        "type": "quantitative",
        "scale": {
          "domain": [3.4, 4.5],
          "range": ["#ecfdf5", "#a7f3d0", "#34d399", "#059669", "#064e3b"]
        },
        "legend": {
          "orient": "bottom",
          "direction": "horizontal",
          "gradientLength": 200,
          "labelFontSize": 12,
          "titleFontSize": 12,
          "title": null,
          "tickCount": 4,
          "padding": 4,
          "offset": 8
        }
      },
      "tooltip": [
        { "field": "scope", "title": "Activity" },
        { "field": "broadband_label", "title": "Broadband" },
        { "field": "metric" },
        { "field": "value", "title": "Score", "format": ".2f" }
      ]
    }
  },
  "resolve": {
    "scale": { "color": "shared" },
    "axis": { "y": "shared" }
  },
  "config": {
    "view": { "stroke": null },
    "facet": { "spacing": 6 },
    "axis": { "labelFontSize": 11, "titleFontSize": 12, "labelColor": "#475569", "titleColor": "#0f172a" }
  }
}
