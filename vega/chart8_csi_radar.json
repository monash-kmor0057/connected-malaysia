{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 480,
  "padding": { "top": 2, "bottom": 12, "left": 4, "right": 4 },
  "data": { "url": "data/csv/bqoes_2024.csv" },
  "transform": [
    { "filter": "datum.category == 'CSI' && datum.scope != 'Overall'" },
    {
      "calculate": "datum.broadband_type == 'FBB' ? 'Fixed broadband (FBB)' : 'Mobile broadband (MBB)'",
      "as": "broadband_label"
    },
    {
      "calculate": "datum.broadband_type == 'MBB' ? 1 : 0",
      "as": "is_mobile"
    }
  ],
  "encoding": {
    "x": {
      "field": "scope",
      "type": "nominal",
      "title": "Online activity",
      "sort": [
        "Video streaming",
        "Web browsing",
        "Online gaming",
        "Online voice calls",
        "Online video calls"
      ],
      "axis": { "labelAngle": -28, "labelFontSize": 11, "titleFontSize": 12 }
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "CSI score (1–5)",
      "scale": { "domain": [3.65, 4.2], "zero": false },
      "axis": { "gridColor": "#e5e7eb" }
    },
    "detail": { "field": "broadband_label" },
    "color": {
      "field": "broadband_label",
      "type": "nominal",
      "scale": {
        "domain": ["Fixed broadband (FBB)", "Mobile broadband (MBB)"],
        "range": ["#2563eb", "#16a34a"]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "title": null,
        "labelFontSize": 11,
        "padding": 4,
        "offset": 14
      }
    }
  },
  "layer": [
    {
      "mark": { "type": "line", "strokeWidth": 2.5, "interpolate": "monotone", "opacity": 0.9 }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 95, "stroke": "#fff", "strokeWidth": 1.5 }
    },
    {
      "transform": [{ "filter": "datum.is_mobile == 0" }],
      "mark": { "type": "text", "dy": -12, "fontSize": 10, "fontWeight": 700, "color": "#1e40af" },
      "encoding": {
        "text": { "field": "value", "type": "quantitative", "format": ".2f" }
      }
    },
    {
      "transform": [{ "filter": "datum.is_mobile == 1" }],
      "mark": { "type": "text", "dy": 14, "fontSize": 10, "fontWeight": 700, "color": "#15803d" },
      "encoding": {
        "text": { "field": "value", "type": "quantitative", "format": ".2f" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "labelColor": "#475569", "titleColor": "#0f172a" }
  }
}
