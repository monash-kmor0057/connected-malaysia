{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 320,
  "height": 250,
  "projection": { "type": "mercator" },
  "layer": [
    {
      "data": {
        "url": "data/geo/basemap_view.json",
        "format": { "type": "geojson" }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eef2f7",
        "stroke": "#94a3b8",
        "strokeWidth": 0.55
      }
    },
    {
      "data": {
        "url": "data/geo/gps_mobile_hexbin_2026.json",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [
        { "calculate": "datum.geometry.coordinates[0]", "as": "lon" },
        { "calculate": "datum.geometry.coordinates[1]", "as": "lat" },
        { "calculate": "datum.properties.rate_mean", "as": "rate_mean" },
        { "filter": "isValid(datum.rate_mean) && isFinite(datum.rate_mean)" }
      ],
      "mark": { "type": "circle", "opacity": 0.85, "stroke": "#ffffff", "strokeWidth": 0.35 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "size": { "value": 52 },
        "color": {
          "field": "rate_mean",
          "type": "quantitative",
          "scale": {
            "domain": [3000, 130000],
            "clamp": true,
            "interpolate": "lab",
            "range": [
              "#3288bd",
              "#66b2d3",
              "#9ecae1",
              "#cfe8f3",
              "#fdd0bc",
              "#fa9a6d",
              "#ef6548",
              "#f03b20"
            ]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "rate_mean", "title": "Mean download (kbps)", "format": ",.0f" },
          { "field": "tests", "title": "Tests in bin", "format": ",.0f" }
        ]
      }
    }
  ],
  "padding": { "left": 0, "top": 0, "right": 0, "bottom": 0 },
  "config": {
    "view": { "stroke": null, "fill": "#ffffff", "clip": true },
    "background": "#ffffff",
    "legend": { "symbolStrokeWidth": 0 }
  }
}
