{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 240,

  "height": 300,

  "title": "2026",

  "projection": {
    "type": "mercator"
  },

  "data": {
    "url": "data/geo/gps_mobile_tiles(2026).json",

    "format": {
      "type": "geojson"
    }
  },

  "mark": {
    "type": "geoshape",

    "stroke": "#ffffff",

    "strokeWidth": 0.3
  },

  "encoding": {

    "color": {

      "field": "properties.avg_d_kbps",

      "type": "quantitative",

      "title": "Download Speed",

      "scale": {

        "domain": [0, 200000],

        "range": [
          "#2563eb",
          "#93c5fd",
          "#fef3c7",
          "#f97316",
          "#dc2626"
        ]
      }
    },

    "tooltip": [

      {
        "field": "properties.avg_d_kbps",

        "title": "Download"
      },

      {
        "field": "properties.avg_u_kbps",

        "title": "Upload"
      }

    ]
  },

  "config": {

    "view": {
      "stroke": null
    }
  }
}
