{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "What Malaysians do online most",
  "width": "container",
  "height": 240,
  "data": {"url": "../../data/cleaned/online_activities.json"},
  "transform": [{"sort": [{"field": "pct", "order": "descending"}]}],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "y": {
          "field": "activity", "type": "nominal", "sort": "-x",
          "title": null, "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "pct", "type": "quantitative",
          "title": "% using each activity",
          "scale": {"domain": [0, 100]},
          "axis": {"grid": true, "gridOpacity": 0.3, "labelFontSize": 11}
        },
        "color": {
          "field": "pct", "type": "quantitative",
          "scale": {"scheme": "greens", "domain": [20, 100]},
          "legend": null
        },
        "tooltip": [
          {"field": "activity", "title": "Activity"},
          {"field": "pct", "title": "% of users", "format": ".0f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 11, "fontWeight": "bold"},
      "encoding": {
        "y": {"field": "activity", "type": "nominal", "sort": "-x"},
        "x": {"field": "pct", "type": "quantitative"},
        "text": {"field": "pct", "format": ".0f"}
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}, "font": "inherit"}
}
