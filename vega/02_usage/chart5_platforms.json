{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Platform dominance - streaming and communication",
  "width": "container",
  "height": 260,
  "data": {"url": "../../data/cleaned/platform_usage.json"},
  "facet": {
    "field": "category", "type": "nominal",
    "title": null,
    "header": {"labelFontSize": 13, "labelFontWeight": "bold", "labelColor": "#2C2C2A"}
  },
  "spec": {
    "width": 180,
    "height": 180,
    "mark": {"type": "arc", "innerRadius": 60, "outerRadius": 90, "stroke": "#fff", "strokeWidth": 1.5},
    "encoding": {
      "theta": {"field": "pct", "type": "quantitative"},
      "color": {
        "field": "platform", "type": "nominal",
        "scale": {
          "domain": ["YouTube","Netflix","TikTok","Others","WhatsApp","Telegram"],
          "range": ["#E24B4A","#185FA5","#1D9E75","#888780","#639922","#534AB7"]
        },
        "legend": {"title": null, "orient": "right", "labelFontSize": 11}
      },
      "tooltip": [
        {"field": "category", "title": "Category"},
        {"field": "platform", "title": "Platform"},
        {"field": "pct", "title": "Share (%)", "format": ".0f"}
      ]
    }
  },
  "config": {"background": "transparent", "view": {"stroke": "transparent"}, "font": "inherit"}
}
