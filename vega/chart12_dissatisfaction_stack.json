{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 300,
  "padding": { "top": 2, "bottom": 0, "left": 0, "right": 0 },
  "data": { "url": "data/csv/bqoes_2024.csv" },
  "transform": [
    { "filter": "datum.category == 'Dissatisfaction_reason'" },
    {
      "calculate": "datum.broadband_type == 'FBB' ? 'Fixed (FBB)' : 'Mobile (MBB)'",
      "as": "broadband_label"
    },
    {
      "joinaggregate": [{ "op": "sum", "field": "value", "as": "total" }],
      "groupby": ["scope", "broadband_label"]
    },
    { "calculate": "round(datum.value / datum.total * 100)", "as": "pct" }
  ],
  "facet": {
    "field": "scope",
    "type": "nominal",
    "columns": 2,
    "sort": [
      "Video streaming",
      "Web browsing",
      "Online gaming",
      "Online voice calls",
      "Online video calls"
    ],
    "title": null,
    "header": {
      "labelFontSize": 10,
      "labelFontWeight": 700,
      "labelColor": "#0f172a",
      "labelLimit": 160,
      "labelAlign": "left",
      "labelAnchor": "start",
      "labelPadding": 6,
      "labelAngle": 0
    }
  },
  "spec": {
    "width": 195,
    "height": 142,
    "padding": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
    "layer": [
      {
        "mark": { "type": "bar", "cornerRadius": 2 },
        "encoding": {
          "x": {
            "field": "broadband_label",
            "type": "nominal",
            "title": null,
            "scale": { "paddingInner": 0.12, "paddingOuter": 0.02 },
            "axis": { "labelFontSize": 9, "labelPadding": 1 }
          },
          "y": {
            "field": "value",
            "type": "quantitative",
            "stack": "normalize",
            "title": null,
            "axis": { "format": "%", "labelFontSize": 9, "titleFontSize": 10, "labelPadding": 2 }
          },
          "color": {
            "field": "label",
            "type": "nominal",
            "scale": { "scheme": "tableau10" },
            "legend": {
              "title": "Reason cited",
              "orient": "bottom",
              "direction": "horizontal",
              "columns": 5,
              "labelFontSize": 7,
              "symbolSize": 30,
              "padding": 0,
              "offset": 2,
              "titlePadding": 2,
              "rowPadding": 0,
              "columnPadding": 3
            }
          },
          "order": { "field": "value", "sort": "descending" },
          "tooltip": [
            { "field": "scope", "title": "Activity" },
            { "field": "broadband_label" },
            { "field": "label", "title": "Reason" },
            { "field": "pct", "title": "Share (%)", "format": ".0f" }
          ]
        }
      },
      {
        "transform": [{ "filter": "datum.pct >= 16" }],
        "mark": { "type": "text", "fontSize": 8, "fontWeight": 700, "color": "white" },
        "encoding": {
          "x": { "field": "broadband_label", "type": "nominal" },
          "y": {
            "field": "value",
            "type": "quantitative",
            "stack": "normalize"
          },
          "detail": { "field": "label" },
          "order": { "field": "value", "sort": "descending" },
          "text": { "field": "pct", "type": "quantitative", "format": ".0f" }
        }
      }
    ]
  },
  "resolve": { "legend": { "color": "shared" } },
  "config": {
    "view": { "stroke": null },
    "facet": { "spacing": 2 },
    "axis": { "titlePadding": 2, "labelPadding": 1 },
    "header": {
      "labelAlign": "left",
      "labelAnchor": "start",
      "labelPadding": 6
    },
    "legend": { "padding": 0, "margin": 0, "titlePadding": 2, "offset": 2 }
  }
}
