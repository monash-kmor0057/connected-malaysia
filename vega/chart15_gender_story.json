{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "vconcat": [
    {
      "width": 340,
      "height": 170,
      "data": {
        "url": "data/csv/gender_internet_use.csv"
      },
      "transform": [
        { "fold": ["female", "male"], "as": ["group", "value"] }
      ],
      "mark": { "type": "line", "point": { "filled": true, "size": 45 }, "strokeWidth": 2.8 },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": { "labelAngle": 0, "grid": false }
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "title": "Internet use (%)",
          "scale": { "domain": [0, 100] },
          "axis": { "gridColor": "#e5e7eb" }
        },
        "color": {
          "field": "group",
          "type": "nominal",
          "scale": { "domain": ["female", "male"], "range": ["#dc2626", "#2563eb"] },
          "legend": { "title": null, "orient": "top" }
        },
        "tooltip": [
          { "field": "year", "type": "ordinal" },
          { "field": "group", "type": "nominal", "title": "Group" },
          { "field": "value", "type": "quantitative", "title": "Internet use (%)", "format": ".2f" }
        ]
      }
    },
    {
      "width": 340,
      "height": 95,
      "data": {
        "url": "data/csv/gender_internet_use.csv"
      },
      "transform": [
        { "calculate": "datum.male - datum.female", "as": "gap" }
      ],
      "layer": [
        {
          "mark": { "type": "bar", "color": "#93c5fd" },
          "encoding": {
            "x": { "field": "year", "type": "ordinal", "axis": { "labelAngle": 0 } },
            "y": {
              "field": "gap",
              "type": "quantitative",
              "title": "Gap (pp)",
              "axis": { "gridColor": "#e5e7eb" }
            },
            "tooltip": [
              { "field": "year", "type": "ordinal" },
              { "field": "gap", "type": "quantitative", "title": "Male - Female", "format": ".2f" }
            ]
          }
        },
        {
          "mark": { "type": "line", "stroke": "#1d4ed8", "strokeWidth": 2, "point": { "filled": true, "size": 28 } },
          "encoding": {
            "x": { "field": "year", "type": "ordinal" },
            "y": { "field": "gap", "type": "quantitative" }
          }
        }
      ]
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "labelFontSize": 10, "titleFontSize": 11, "labelColor": "#374151", "titleColor": "#111827" },
    "legend": { "labelFontSize": 10, "titleFontSize": 10 }
  }
}
