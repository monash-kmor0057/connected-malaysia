{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 104,
  "padding": { "top": 0, "bottom": 2, "left": 0, "right": 8 },
  "data": { "url": "data/csv/chart11/chart11_video_calls.csv" },
  "transform": [
    {
      "impute": "value",
      "key": "label",
      "groupby": ["broadband_label", "broadband_type", "scope"],
      "value": 0,
      "frame": "merged"
    },
    { "calculate": "format(datum.value, '.1f') + '%'", "as": "pct_label" }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 2, "height": 12 },
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "title": null,
          "sort": { "field": "value", "op": "max", "order": "descending" },
          "scale": { "paddingInner": 0.4, "paddingOuter": 0.08 },
          "axis": {
            "labelFontSize": 11,
            "labelLimit": 110,
            "labelPadding": 3,
            "minExtent": 112,
            "maxExtent": 112
          }
        },
        "x": {
          "field": "value",
          "type": "quantitative",
          "scale": { "domain": [0, 100] },
          "axis": {
            "title": null,
            "labelFontSize": 11,
            "labelPadding": 3,
            "values": [0, 20, 40, 60, 80, 100],
            "labelExpr": "format(datum.value, '.0f') + '%'",
            "grid": false
          }
        },
        "color": {
          "field": "broadband_label",
          "type": "nominal",
          "scale": {
            "domain": ["Fixed (FBB)", "Mobile (MBB)"],
            "range": ["#2563eb", "#16a34a"]
          },
          "legend": null
        },
        "yOffset": {
          "field": "broadband_label",
          "scale": { "paddingInner": 0.75, "paddingOuter": 0.12 }
        },
        "tooltip": [
          { "field": "label", "title": "Platform" },
          { "field": "broadband_label", "title": "Broadband" },
          { "field": "value", "title": "Share (%)", "format": ".1f" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 10,
        "fontWeight": 600,
        "fill": "#334155"
      },
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": { "field": "value", "op": "max", "order": "descending" }
        },
        "x": { "field": "value", "type": "quantitative" },
        "yOffset": {
          "field": "broadband_label",
          "scale": { "paddingInner": 0.75, "paddingOuter": 0.12 }
        },
        "text": { "field": "pct_label", "type": "nominal" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "labelFontSize": 11, "titleFontSize": 12 },
    "scale": { "offsetBandPaddingInner": 0.75 }
  }
}
