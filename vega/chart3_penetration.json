{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 260,
  "height": 220,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of 3G subscriptions'"
    },
    {
      "filter": "datum.SubItems == 'Prepaid'"
    }
  ],

  "mark": {
    "type": "bar",
    "color": "#f59e0b"
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value",
      "type": "quantitative"
    }
  }
}
