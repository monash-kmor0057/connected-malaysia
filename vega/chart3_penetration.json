{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 260,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of broadband subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == 'Wireless' || datum['Sub-Items'] == 'Fixed'"
    },

    {
      "filter": "datum.Value_in_Thousand > 0"
    }

  ],

  "mark": {
    "type": "area",
    "opacity": 0.75
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "stack": true,
      "title": "Broadband subscriptions"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal",

      "scale": {
        "range": ["#38bdf8", "#1d4ed8"]
      }
    }
  }
}
