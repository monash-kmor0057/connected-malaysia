{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 240,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of 3G subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == 'Prepaid' || datum['Sub-Items'] == 'Postpaid'"
    }

  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "title": "3G subscriptions"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal",

      "scale": {
        "range": ["#f59e0b", "#fde68a"]
      },

      "legend": {
        "title": null,
        "orient": "top"
      }
    },

    "tooltip": [

      {
        "field": "Year"
      },

      {
        "field": "Sub-Items"
      },

      {
        "field": "Value_in_Thousand"
      }

    ]
  }
}
