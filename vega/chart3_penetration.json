{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 260,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of broadband subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == 'Wireless' || datum['Sub-Items'] == 'Fixed'"
    },

    {
      "filter": "datum.Value_in_Thousand > 0"
    }

  ],

  "mark": {
    "type": "area"
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "ordinal"
    },

    "y": {
      "field": "Value_in_Thousand",
      "stack": "normalize",
      "type": "quantitative"
    },

    "color": {
      "field": "Sub-Items",

      "scale": {
        "range": [
          "#38bdf8",
          "#1d4ed8"
        ]
      }
    }
  }
}
