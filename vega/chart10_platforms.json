{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 360,
  "height": 320,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Platform_share'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "filter": "datum.value > 5"
    },

    {
      "calculate": "datum.label == 'WhatsApp' || datum.label == 'Telegram' || datum.label == 'Messenger' ? 'Messaging' : datum.label == 'YouTube' || datum.label == 'Netflix' || datum.label == 'Spotify' ? 'Streaming' : datum.label == 'Shopee' || datum.label == 'Grab' ? 'Commerce' : 'Social'",
      "as": "Group"
    }

  ],

  "mark": {
    "type": "circle",
    "opacity": 0.8,
    "stroke": "white",
    "strokeWidth": 2
  },

  "encoding": {

    "x": {
      "field": "Group",
      "type": "nominal"
    },

    "y": {
      "field": "value",
      "type": "quantitative"
    },

    "size": {
      "field": "value",
      "type": "quantitative"
    },

    "color": {
      "field": "Group",

      "scale": {
        "range": [
          "#2563eb",
          "#16a34a",
          "#f59e0b",
          "#ef4444"
        ]
      }
    },

    "tooltip": [
      {
        "field": "label"
      },
      {
        "field": "value"
      }
    ]
  }
}
