{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",

  "height": 340,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Platform_share'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "filter": "datum.value > 5"
    },

    {
      "calculate": "datum.label == 'WhatsApp' || datum.label == 'Telegram' || datum.label == 'Messenger' ? 'Messaging' : datum.label == 'Shopee' || datum.label == 'Grab' ? 'Commerce' : datum.label == 'YouTube' || datum.label == 'Netflix' || datum.label == 'Spotify' ? 'Streaming' : 'Social'",
      "as": "Group"
    }

  ],

  "facet": {

    "field": "Group",

    "type": "nominal",

    "columns": 2,

    "header": {
      "titleFontSize": 18,
      "labelFontSize": 16
    }
  },

  "spec": {

    "mark": {
      "type": "circle",
      "opacity": 0.85,
      "stroke": "white",
      "strokeWidth": 2
    },

    "encoding": {

      "x": {
        "field": "label",
        "type": "nominal",
        "axis": {
          "labelAngle": -25,
          "labelFontSize": 11
        }
      },

      "y": {
        "field": "value",
        "type": "quantitative",
        "title": "%"
      },

      "size": {
        "field": "value",
        "type": "quantitative",
        "scale": {
          "range": [400, 4000]
        }
      },

      "color": {
        "field": "Group",

        "scale": {
          "range": [
            "#2563eb",
            "#16a34a",
            "#f59e0b",
            "#ef4444"
          ]
        }
      },

      "tooltip": [

        {
          "field": "label",
          "title": "Platform"
        },

        {
          "field": "value",
          "title": "Usage %"
        }

      ]
    }
  },

  "config": {

    "view": {
      "stroke": null
    }
  }
}
