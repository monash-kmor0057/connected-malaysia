{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 320,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Platform_share'"
    },

    {
      "filter": "datum.year == 2024"
    }

  ],

  "mark": {
    "type": "arc",
    "innerRadius": 80,
    "stroke": "white",
    "strokeWidth": 3
  },

  "encoding": {

    "theta": {
      "field": "value",
      "type": "quantitative"
    },

    "color": {
      "field": "label",

      "scale": {
        "range": [
          "#2563eb",
          "#16a34a",
          "#f59e0b",
          "#ef4444",
          "#8b5cf6"
        ]
      }
    }
  }
}
