{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 280,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Dissatisfaction_reason'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "filter": "datum.value > 20"
    }

  ],

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 5
  },

  "encoding": {

    "y": {
      "field": "label",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },

    "x": {
      "field": "value",
      "type": "quantitative",
      "title": "%"
    },

    "color": {
      "field": "scope",

      "scale": {
        "range": [
          "#ef4444",
          "#f97316",
          "#f59e0b",
          "#2563eb"
        ]
      }
    }
  }
}
