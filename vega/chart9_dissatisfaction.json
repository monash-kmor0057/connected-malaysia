{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 260,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Dissatisfaction_reason'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "calculate": "-datum.value",
      "as": "negative"
    }

  ],

  "mark": {
    "type": "bar"
  },

  "encoding": {

    "y": {
      "field": "label",
      "type": "nominal"
    },

    "x": {
      "field": "negative",
      "type": "quantitative"
    },

    "color": {
      "value": "#ef4444"
    }
  }
}
