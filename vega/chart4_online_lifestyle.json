{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 340,
  "height": 300,
  "data": {
    "url": "data/csv/section1_worldbank_long.csv"
  },
  "transform": [
    { "filter": "datum.indicator == 'Fixed broadband subscriptions per 100'" },
    { "calculate": "datum.year", "as": "year_num" },
    { "calculate": "datum.value", "as": "value_num" },
    { "filter": "isValid(datum.value_num) && datum.value_num > 0" }
  ],
  "resolve": { "axis": { "x": "shared", "y": "shared" } },
  "layer": [
    {
      "transform": [{ "filter": "datum.year_num >= 2020" }],
      "mark": { "type": "area", "color": "#99f6e4", "opacity": 0.22 },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative",
          "title": "Year",
          "scale": { "domain": [1986, 2024], "nice": false, "padding": 0 },
          "axis": { "labelAngle": 0, "tickCount": 6, "grid": false }
        },
        "y": {
          "field": "value_num",
          "type": "quantitative",
          "scale": { "zero": true, "domainMax": 17.2, "nice": false, "paddingTop": 52 },
          "title": "Subscriptions per 100 people",
          "axis": { "gridColor": "#e5e7eb" }
        },
        "y2": { "datum": 0 }
      }
    },
    {
      "mark": { "type": "line", "stroke": "#0f766e", "strokeWidth": 3.5, "point": { "filled": true, "size": 50 } },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative",
          "scale": { "domain": [1986, 2024], "nice": false, "padding": 0 }
        },
        "y": {
          "field": "value_num",
          "type": "quantitative",
          "scale": { "zero": true, "domainMax": 17.2, "nice": false, "paddingTop": 52 }
        },
        "tooltip": [
          { "field": "year_num", "type": "quantitative", "title": "Year" },
          { "field": "value_num", "type": "quantitative", "title": "Fixed per 100", "format": ".2f" }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2008,
            "label": "HSBB",
            "color": "#a16207",
            "label_y": 16.5,
            "label_align": "right",
            "label_dx": -8
          },
          {
            "year": 2010,
            "label": "NBI",
            "color": "#c2410c",
            "label_y": 15.9,
            "label_align": "left",
            "label_dx": 8
          },
          {
            "year": 2015,
            "label": "HSBB2",
            "color": "#5b21b6",
            "label_y": 15.2,
            "label_align": "left",
            "label_dx": 8
          },
          {
            "year": 2020,
            "label": "JENDELA",
            "color": "#b91c1c",
            "label_y": 14.6,
            "label_align": "left",
            "label_dx": 8
          }
        ]
      },
      "transform": [{ "calculate": "datum.year", "as": "year_num" }],
      "layer": [
        {
          "mark": { "type": "rule", "strokeDash": [6, 4], "strokeWidth": 2, "opacity": 0.85 },
          "encoding": {
            "x": {
              "field": "year_num",
              "type": "quantitative",
              "scale": { "domain": [1986, 2024], "nice": false, "padding": 0 }
            },
            "color": { "field": "color", "type": "nominal", "scale": null, "legend": null }
          }
        },
        {
          "mark": { "type": "text", "baseline": "bottom", "dy": -8, "fontSize": 11, "fontWeight": 700 },
          "encoding": {
            "x": {
              "field": "year_num",
              "type": "quantitative",
              "scale": { "domain": [1986, 2024], "nice": false, "padding": 0 }
            },
            "y": { "field": "label_y", "type": "quantitative" },
            "text": { "field": "label", "type": "nominal" },
            "align": { "field": "label_align", "type": "nominal" },
            "dx": { "field": "label_dx", "type": "quantitative" },
            "color": { "field": "color", "type": "nominal", "scale": null, "legend": null }
          }
        }
      ]
    }
  ],
  "padding": { "top": 14, "bottom": 18, "left": 8, "right": 10 },
  "config": {
    "view": { "stroke": null, "clip": false },
    "axis": { "labelFontSize": 11, "titleFontSize": 12, "labelColor": "#374151", "titleColor": "#111827" }
  }
}
