{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 300,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Participation'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "filter": "datum.broadband_type == 'MBB'"
    }

  ],

  "mark": {
    "type": "circle",
    "opacity": 0.8,
    "stroke": "white",
    "strokeWidth": 2
  },

  "encoding": {

    "x": {
      "field": "scope",
      "type": "nominal",
      "sort": "-y"
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Participation (%)"
    },

    "size": {
      "field": "value",
      "type": "quantitative"
    },

    "color": {
      "field": "scope",

      "scale": {
        "range": [
          "#2563eb",
          "#0ea5e9",
          "#14b8a6",
          "#16a34a",
          "#f59e0b",
          "#ef4444"
        ]
      }
    },

    "tooltip": [
      {
        "field": "scope"
      },
      {
        "field": "value"
      }
    ]
  }
}
