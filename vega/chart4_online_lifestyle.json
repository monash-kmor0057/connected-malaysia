{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 340,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Participation'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "filter": "datum.broadband_type == 'MBB'"
    }

  ],

  "layer": [

    {
      "mark": {
        "type": "line",
        "strokeWidth": 4,
        "color": "#2563eb"
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 100,
        "color": "#2563eb"
      }
    }

  ],

  "encoding": {

    "theta": {
      "field": "scope",
      "type": "nominal"
    },

    "radius": {
      "field": "value",
      "type": "quantitative",

      "scale": {
        "domain": [0, 100]
      }
    }
  }
}
