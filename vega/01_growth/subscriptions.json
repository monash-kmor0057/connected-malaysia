{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Broadband and mobile subscriptions growth 2000–2024",
  "width": "container",
  "height": 220,
  "background": "transparent",
  "config": {
    "font": "DM Sans, sans-serif",
    "axis": {
      "labelColor": "#64748b",
      "titleColor": "#475569",
      "gridColor": "#e2e8f0",
      "domainColor": "#cbd5e1",
      "tickColor": "#cbd5e1",
      "labelFontSize": 11,
      "titleFontSize": 11
    },
    "legend": {
      "labelColor": "#475569",
      "titleColor": "#475569",
      "labelFontSize": 11
    },
    "view": { "stroke": "transparent" }
  },
  "data": { "url": "../../data/cleaned/subscriptions.csv" },
  "transform": [
    {
      "fold": ["mobile_subs", "broadband_subs"],
      "as": ["type", "value"]
    },
    {
      "calculate": "datum.type === 'mobile_subs' ? 'Mobile subscriptions' : 'Broadband subscriptions'",
      "as": "label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "opacity": 0.08,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "axis": { "format": "d", "title": null } },
        "y": { "field": "value", "type": "quantitative", "axis": { "title": "Subscriptions (million)" } },
        "color": {
          "field": "label",
          "scale": {
            "domain": ["Mobile subscriptions", "Broadband subscriptions"],
            "range": ["#1d4ed8", "#0ea5e9"]
          }
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "axis": { "format": "d", "title": null } },
        "y": { "field": "value", "type": "quantitative" },
        "color": {
          "field": "label",
          "legend": { "title": null, "orient": "top-left" },
          "scale": {
            "domain": ["Mobile subscriptions", "Broadband subscriptions"],
            "range": ["#1d4ed8", "#0ea5e9"]
          }
        }
      }
    },
    {
      "transform": [
        { "filter": "datum.year === 2024" }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 60
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative" },
        "y": { "field": "value", "type": "quantitative" },
        "color": {
          "field": "label",
          "scale": {
            "domain": ["Mobile subscriptions", "Broadband subscriptions"],
            "range": ["#1d4ed8", "#0ea5e9"]
          }
        }
      }
    }
  ]
}
