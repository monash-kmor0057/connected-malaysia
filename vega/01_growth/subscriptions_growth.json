{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "./data/raw/2000-2021-telecommunications-statistics-malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Cellular Phone Subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative",
      "title": "Subscriptions (Thousands)"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal"
    }
  }
}
