{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "/connected-malaysia/data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "(datum.Items == 'Number of Cellular phones subscriptions' && datum['Sub-Items'] == 'Number of Cellular phones subscriptions') || (datum.Items == 'Number of broadband subscriptions' && datum['Sub-Items'] == 'Number of broadband subscriptions')"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative",
      "title": "Subscriptions (Thousands)"
    },

    "color": {
      "field": "Items",
      "type": "nominal",
      "title": "Type"
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "quantitative"
      },
      {
        "field": "Items",
        "type": "nominal"
      },
      {
        "field": "Value in Thousand",
        "type": "quantitative"
      }
    ]
  }
}
