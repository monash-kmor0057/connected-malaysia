{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "/connected-malaysia/data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    },

    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Value in Thousand",
          "as": "TotalSubscriptions"
        }
      ],

      "groupby": ["Year"]
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "TotalSubscriptions",
      "type": "quantitative",
      "title": "Subscriptions (Thousands)"
    }
  }
}
