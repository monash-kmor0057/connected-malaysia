{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "data/cleaned/subscriptions_growth.csv"
  },

  "transform": [
    {
      "fold": ["mobile", "broadband"],
      "as": ["type", "value"]
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {

    "x": {
      "field": "year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Subscriptions (Millions)"
    },

    "color": {
      "field": "type",
      "type": "nominal",
      "title": "Connection Type"
    }
  }
}
