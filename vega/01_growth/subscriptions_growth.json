{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "../../data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal"
    }
  }
}
