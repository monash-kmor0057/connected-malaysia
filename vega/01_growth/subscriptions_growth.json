{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "./data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative",
      "title": "Subscriptions (Thousands)"
    },

    "color": {
      "field": "Sub-Items",
      "type": "nominal",
      "title": "Subscription Type"
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "quantitative"
      },
      {
        "field": "Sub-Items",
        "type": "nominal"
      },
      {
        "field": "Value in Thousand",
        "type": "quantitative"
      }
    ]
  }
}
