{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "/connected-malaysia/data/raw/telecommunications_statistics_malaysia.csv"
  },

  "mark": {
    "type": "line"
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative"
    },

    "color": {
      "field": "Items",
      "type": "nominal"
    }
  }
}
