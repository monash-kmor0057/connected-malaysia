{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 168,
  "padding": { "top": 0, "bottom": 0, "left": 4, "right": 4 },
  "data": { "url": "data/csv/bqoes_2024.csv" },
  "transform": [
    { "filter": "datum.category == 'Demo' && datum.scope == 'Ethnicity'" },
    {
      "calculate": "datum.broadband_type == 'FBB' ? 'Fixed (FBB)' : 'Mobile (MBB)'",
      "as": "broadband_label"
    }
  ],
  "encoding": {
    "y": {
      "field": "label",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "axis": { "labelFontSize": 10 }
    },
    "x": {
      "field": "value",
      "type": "quantitative",
      "title": "% of sample",
      "scale": { "domain": [0, 80] },
      "axis": { "gridColor": "#e5e7eb" }
    },
    "color": {
      "field": "broadband_label",
      "type": "nominal",
      "scale": {
        "domain": ["Fixed (FBB)", "Mobile (MBB)"],
        "range": ["#2563eb", "#16a34a"]
      },
      "legend": null
    },
    "yOffset": { "field": "broadband_label" }
  },
  "layer": [
    { "mark": { "type": "bar", "cornerRadiusEnd": 3, "height": 16 } },
    {
      "mark": { "type": "text", "dx": 5, "fontSize": 9, "fontWeight": 700, "align": "left", "color": "#334155" },
      "encoding": {
        "text": { "field": "value", "type": "quantitative", "format": ".1f" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "labelFontSize": 10, "titleFontSize": 11 }
  }
}
