{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 280,
  "height": 220,

  "data": {
    "url": "../data/raw/telecommunications_statistics_malaysia.csv",
    "format": {
      "type": "csv"
    }
  },

  "transform": [
    {
      "filter": "datum.Items === 'Number of broadband subscriptions'"
    },
    {
      "calculate": "toNumber(datum['Value in Thousand'])",
      "as": "value"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3,
    "color": "#2563eb"
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Subscriptions (Thousand)",
      "scale": {
        "domainMin": 0
      }
    },

    "tooltip": [
      {
        "field": "Year"
      },
      {
        "field": "value"
      }
    ]
  }
}
