{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 340,
  "height": 280,
  "data": {
    "url": "data/csv/section1_worldbank_long.csv"
  },
  "transform": [
    { "filter": "datum.indicator == 'Mobile subscriptions'" },
    { "calculate": "datum.year", "as": "year_num" },
    { "calculate": "datum.value", "as": "value_num" },
    { "filter": "isValid(datum.value_num) && datum.value_num > 0" },
    {
      "window": [{ "op": "mean", "field": "value_num", "as": "smooth_value" }],
      "frame": [-2, 2],
      "sort": [{ "field": "year_num", "order": "ascending" }]
    }
  ],
  "layer": [
    {
      "mark": { "type": "area", "color": "#3b82f6", "opacity": 0.14 },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative",
          "title": "Year",
          "axis": { "labelAngle": 0, "tickCount": 6, "grid": false }
        },
        "y": {
          "field": "value_num",
          "type": "quantitative",
          "scale": { "domainMin": 0, "domainMax": 50000000, "nice": false, "paddingTop": 84 },
          "title": "Mobile subscriptions",
          "axis": { "gridColor": "#e5e7eb" }
        }
      }
    },
    {
      "mark": { "type": "line", "stroke": "#2563eb", "strokeWidth": 3.5, "point": { "filled": true, "size": 55 } },
      "encoding": {
        "x": { "field": "year_num", "type": "quantitative" },
        "y": { "field": "value_num", "type": "quantitative", "scale": { "domainMin": 0, "domainMax": 50000000, "nice": false, "paddingTop": 84 } },
        "tooltip": [
          { "field": "year_num", "type": "quantitative", "title": "Year" },
          { "field": "value_num", "type": "quantitative", "title": "Subscriptions" }
        ]
      }
    },
    {
      "mark": { "type": "line", "stroke": "#1d4ed8", "strokeDash": [5, 5], "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "year_num", "type": "quantitative" },
        "y": { "field": "smooth_value", "type": "quantitative", "scale": { "domainMin": 0, "domainMax": 50000000, "nice": false, "paddingTop": 84 } },
        "tooltip": [
          { "field": "year_num", "type": "quantitative", "title": "Year" },
          { "field": "smooth_value", "type": "quantitative", "title": "5-year moving average", "format": ".0f" }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "year": 2013, "label": "4G LTE start", "color": "#5b21b6", "label_y": 48900000 },
          { "year": 2020, "label": "JENDELA", "color": "#b91c1c", "label_y": 47700000 },
          { "year": 2021, "label": "5G start", "color": "#0891b2", "label_y": 46400000 }
        ]
      },
      "transform": [
        { "calculate": "datum.year", "as": "year_num" },
        { "filter": "datum.label != '5G start'" }
      ],
      "layer": [
        {
          "mark": { "type": "rule", "strokeDash": [6, 4], "strokeWidth": 2, "opacity": 0.85 },
          "encoding": {
            "x": { "field": "year_num", "type": "quantitative" },
            "color": { "field": "color", "type": "nominal", "scale": null, "legend": null }
          }
        },
        {
          "mark": { "type": "text", "align": "right", "dx": -10, "baseline": "bottom", "dy": -8, "fontSize": 10, "fontWeight": 700 },
          "encoding": {
            "x": { "field": "year_num", "type": "quantitative" },
            "y": { "field": "label_y", "type": "quantitative" },
            "text": { "field": "label", "type": "nominal" },
            "color": { "field": "color", "type": "nominal", "scale": null, "legend": null }
          }
        }
      ]
    },
    {
      "data": {
        "values": [
          { "year": 2021, "label": "5G start", "color": "#0891b2", "label_y": 46400000 }
        ]
      },
      "transform": [
        { "calculate": "datum.year", "as": "year_num" },
        { "filter": "datum.label == '5G start'" }
      ],
      "layer": [
        {
          "mark": { "type": "rule", "strokeDash": [6, 4], "strokeWidth": 2, "opacity": 0.85 },
          "encoding": {
            "x": { "field": "year_num", "type": "quantitative" },
            "color": { "field": "color", "type": "nominal", "scale": null, "legend": null }
          }
        },
        {
          "mark": { "type": "text", "align": "left", "dx": 10, "baseline": "bottom", "dy": -8, "fontSize": 10, "fontWeight": 700 },
          "encoding": {
            "x": { "field": "year_num", "type": "quantitative" },
            "y": { "field": "label_y", "type": "quantitative" },
            "text": { "field": "label", "type": "nominal" },
            "color": { "field": "color", "type": "nominal", "scale": null, "legend": null }
          }
        }
      ]
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "labelFontSize": 11, "titleFontSize": 12, "labelColor": "#374151", "titleColor": "#111827" }
  }
}
