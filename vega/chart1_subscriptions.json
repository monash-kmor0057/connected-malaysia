{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 240,

  "data": {
    "url": "../data/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.variable == 'Mobile subscriptions' || datum.variable == 'Broadband subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Subscriptions (million)"
    },

    "color": {
      "field": "variable",
      "type": "nominal",
      "scale": {
        "range": ["#1d4ed8", "#15803d"]
      }
    }
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}
