{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,

  "height": 260,

  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "background": null,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' || datum.Items == 'Number of broadband subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == datum.Items"
    },

    {
      "filter": "datum.Value_in_Thousand > 0"
    },

    {
      "calculate": "datum.Items == 'Number of Cellular phones subscriptions' ? 'Mobile' : 'Broadband'",
      "as": "Category"
    }

  ],

  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 70
    },
    "strokeWidth": 3
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year",

      "axis": {
        "labelAngle": 0,
        "tickCount": 6
      }
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "title": "Subscriptions",

      "axis": {
        "gridColor": "#e5e7eb"
      }
    },

    "color": {
      "field": "Category",
      "type": "nominal",

      "scale": {
        "range": [
          "#2563eb",
          "#16a34a"
        ]
      },

      "legend": {
        "title": null,
        "orient": "top"
      }
    },

    "tooltip": [

      {
        "field": "Year",
        "type": "quantitative"
      },

      {
        "field": "Category",
        "type": "nominal"
      },

      {
        "field": "Value_in_Thousand",
        "type": "quantitative",
        "title": "Subscriptions"
      }

    ]
  },

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}
