{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 220,

  "data": {
    "url": "../data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' && datum['Sub-Items'] == 'Number of Cellular phones subscriptions'"
    },
    {
      "calculate": "toNumber(datum['Value in Thousand'])",
      "as": "value"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3,
    "color": "#2563eb"
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal"
    },

    "y": {
      "field": "value",
      "type": "quantitative"
    }
  }
}
