{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 240,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' || datum.Items == 'Number of broadband subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == datum.Items"
    },

    {
      "calculate": "datum.Items == 'Number of Cellular phones subscriptions' ? 'Mobile' : 'Broadband'",
      "as": "Category"
    }

  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative",
      "title": "Subscriptions"
    },

    "color": {
      "field": "Category",
      "type": "nominal",

      "scale": {
        "range": ["#2563eb", "#16a34a"]
      },

      "legend": {
        "title": null,
        "orient": "top"
      }
    },

    "tooltip": [

      {
        "field": "Year"
      },

      {
        "field": "Category"
      },

      {
        "field": "Value_in_Thousand"
      }

    ]
  }
}
