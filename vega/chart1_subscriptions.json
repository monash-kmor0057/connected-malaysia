{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 220,

  "data": {
    "url": "../data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(datum['Value in Thousand'])",
      "as": "value"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal"
    },

    "y": {
      "field": "value",
      "type": "quantitative"
    },

    "color": {
      "field": "Items",
      "type": "nominal"
    }
  }
}
