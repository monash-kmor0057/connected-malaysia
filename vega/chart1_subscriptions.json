{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 500,

  "height": 300,

  "background": null,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [

    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' || datum.Items == 'Number of broadband subscriptions'"
    },

    {
      "filter": "datum['Sub-Items'] == datum.Items"
    },

    {
      "filter": "datum.Value_in_Thousand > 0"
    }

  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 4
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "ordinal"
    },

    "y": {
      "field": "Value_in_Thousand",
      "type": "quantitative"
    },

    "color": {
      "field": "Items",
      "type": "nominal"
    }
  }
}
