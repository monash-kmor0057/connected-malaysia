{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 260,
  "height": 220,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of broadband subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3,
    "color": "#2563eb"
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative"
    },

    "y": {
      "field": "Value",
      "type": "quantitative"
    }
  }
}
