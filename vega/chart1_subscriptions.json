{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 240,

  "data": {
    "url": "../data/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' || datum.Items == 'Number of broadband subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative"
    },

    "color": {
      "field": "Items",
      "type": "nominal"
    }
  }
}
