{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 240,

  "data": {
    "url": "../data/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' || datum.Items == 'Number of broadband subscriptions'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "Value in Thousand",
      "type": "quantitative",
      "title": "Subscriptions (Thousand)"
    },

    "color": {
      "field": "Items",
      "type": "nominal",
      "legend": {
        "title": null
      }
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal"
      },
      {
        "field": "Items",
        "type": "nominal"
      },
      {
        "field": "Value in Thousand",
        "type": "quantitative"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}
