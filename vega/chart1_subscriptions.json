{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 300,
  "height": 240,

  "data": {
    "url": "data/raw/telecommunications_statistics_malaysia.csv"
  },

  "transform": [
    {
      "filter": "datum.Items == 'Number of Cellular phones subscriptions' || datum.Items == 'Number of broadband subscriptions'"
    },

    {
      "filter": "datum.SubItems == datum.Items"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Value",
      "type": "quantitative",
      "title": "Subscriptions (Thousand)"
    },

    "color": {
      "field": "Items",
      "type": "nominal",
      "scale": {
        "range": ["#2563eb", "#16a34a"]
      },
      "legend": {
        "title": null
      }
    },

    "tooltip": [
      {
        "field": "Year"
      },
      {
        "field": "Items"
      },
      {
        "field": "Value"
      }
    ]
  }
}
