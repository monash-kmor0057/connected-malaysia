{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 260,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'CSI'"
    },

    {
      "filter": "datum.scope == 'Overall'"
    }

  ],

  "layer": [

    {
      "mark": {
        "type": "rule",
        "strokeWidth": 4,
        "color": "#94a3b8"
      },

      "encoding": {

        "x": {
          "field": "broadband_type",
          "type": "nominal"
        },

        "y": {
          "value": 0
        },

        "y2": {
          "field": "value"
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 220
      },

      "encoding": {

        "x": {
          "field": "broadband_type",
          "type": "nominal"
        },

        "y": {
          "field": "value",
          "type": "quantitative"
        },

        "color": {
          "field": "year",

          "scale": {
            "range": [
              "#2563eb",
              "#16a34a"
            ]
          }
        }
      }
    }

  ]
}
