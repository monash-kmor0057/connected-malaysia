{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 340,
  "height": 260,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'CSI'"
    },

    {
      "filter": "datum.scope == 'Overall'"
    }

  ],

  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 6,
    "cornerRadiusTopRight": 6
  },

  "encoding": {

    "x": {
      "field": "broadband_type",
      "type": "nominal",
      "title": null
    },

    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Satisfaction Score"
    },

    "color": {
      "field": "broadband_type",

      "scale": {
        "range": [
          "#2563eb",
          "#16a34a"
        ]
      }
    },

    "column": {
      "field": "year",
      "type": "ordinal"
    }
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}
