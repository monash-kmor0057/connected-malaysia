{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 320,
  "height": 260,

  "data": {
    "url": "data/raw/bqoes(2024vs2023).csv"
  },

  "transform": [

    {
      "filter": "datum.category == 'Participation'"
    },

    {
      "filter": "datum.year == 2024"
    },

    {
      "filter": "datum.broadband_type == 'MBB'"
    }

  ],

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 5
  },

  "encoding": {

    "y": {
      "field": "scope",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },

    "x": {
      "field": "value",
      "type": "quantitative",
      "title": "Participation (%)",

      "scale": {
        "domain": [0, 100]
      }
    },

    "color": {
      "field": "scope",
      "legend": null,

      "scale": {
        "range": [
          "#2563eb",
          "#0ea5e9",
          "#16a34a",
          "#f59e0b"
        ]
      }
    }
  }
}
